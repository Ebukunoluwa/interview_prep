# Copy this file to backend/.env and fill in your keys.

# ── STT ────────────────────────────────────────────────────────────────────
# Free tier: https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── LLM ────────────────────────────────────────────────────────────────────
# Free tier (Llama 3.3 70B): https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here


# ── TTS (choose one) ────────────────────────────────────────────────────────
# Option A — Kokoro via Hugging Face (free)
# Get token at https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_hf_token_here

# Option B — ElevenLabs (free tier: 10k chars/month)
# https://elevenlabs.io
# ELEVENLABS_API_KEY=

# ── LiveKit ─────────────────────────────────────────────────────────────────
# Free cloud tier: https://livekit.io/cloud  →  create a project
LIVEKIT_URL=wss://your-app.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── Server ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
